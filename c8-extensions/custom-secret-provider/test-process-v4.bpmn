<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  id="secret-test-process-v4"
                  targetNamespace="http://camunda.org/examples">
  
  <bpmn:process id="secret-test-v4" name="Secret Provider Test v4" isExecutable="true">
    
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_to_test_connector</bpmn:outgoing>
    </bpmn:startEvent>
    
    <!-- Step 1: GET local connector health with secret in query param -->
    <bpmn:serviceTask id="test-secret-connector" name="Test Secret Resolution">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1"/>
        <zeebe:ioMapping>
          <zeebe:input source="=&quot;http://localhost:8080/actuator/health&quot;" target="url"/>
          <zeebe:input source="=&quot;get&quot;" target="method"/>
          <zeebe:input source="={x:&quot;{{secrets.MY_TEST_KEY}}&quot;}" target="queryParameters"/>
          <zeebe:output source="=body" target="healthResponse"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_test_connector</bpmn:incoming>
      <bpmn:outgoing>Flow_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_to_end</bpmn:incoming>
    </bpmn:endEvent>
    
    <bpmn:sequenceFlow id="Flow_to_test_connector" sourceRef="StartEvent_1" targetRef="test-secret-connector"/>
    <bpmn:sequenceFlow id="Flow_to_end" sourceRef="test-secret-connector" targetRef="EndEvent_1"/>
    
  </bpmn:process>
  
</bpmn:definitions>
